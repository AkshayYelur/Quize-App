generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuizHistory {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  topic          String
  difficulty     String
  totalQuestions Int
  correct        Int
  wrong          Int
  scorePercent   Float
  questions      Json
}
